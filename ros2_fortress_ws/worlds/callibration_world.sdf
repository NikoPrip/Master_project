<?xml version="1.0" ?>
<sdf version="1.8">
    <world name="car_world">
        <physics name="1ms" type="ignored">
            <max_step_size>0.001</max_step_size>
            <real_time_factor>1.0</real_time_factor>
        </physics>
        <plugin
            filename="libignition-gazebo-physics-system.so"
            name="ignition::gazebo::systems::Physics">
        </plugin>
        <plugin
            filename="libignition-gazebo-user-commands-system.so"
            name="ignition::gazebo::systems::UserCommands">
        </plugin>
        <plugin
            filename="libignition-gazebo-scene-broadcaster-system.so"
            name="ignition::gazebo::systems::SceneBroadcaster">
        </plugin>
        <plugin
            filename="libignition-gazebo-sensors-system.so"
            name="ignition::gazebo::systems::Sensors">
            <render_engine>ogre2</render_engine>
        </plugin>

        <light type="directional" name="sun">
            <cast_shadows>true</cast_shadows>
            <pose>0 0 10 0 0 0</pose>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
            <attenuation>
                <range>1000</range>
                <constant>0.9</constant>
                <linear>0.01</linear>
                <quadratic>0.001</quadratic>
            </attenuation>
            <direction>-0.5 0.1 -0.9</direction>
        </light>

        <model name="ground_plane">
            <static>true</static>
            <link name="link">
                <collision name="collision">
                <geometry>
                    <plane>
                    <normal>0 0 1</normal>
                    </plane>
                </geometry>
                </collision>
                <visual name="visual">
                <geometry>
                    <plane>
                    <normal>0 0 1</normal>
                    <size>100 100</size>
                    </plane>
                </geometry>
                <material>
                    <ambient>0.8 0.8 0.8 1</ambient>
                    <diffuse>0.8 0.8 0.8 1</diffuse>
                    <specular>0.8 0.8 0.8 1</specular>
                </material>
                </visual>
            </link>
        </model>

        <model name="camera_model">
            <static>true</static>
            <pose>0 0 0 0 0 3.1416</pose>

            <!-- 1-metre pole -->
            <link name="pole">
                <pose>0 0 0.45 0 0 0</pose>
                <collision name="pole_collision">
                    <geometry>
                        <cylinder>
                            <radius>0.05</radius>
                            <length>0.9</length>
                        </cylinder>
                    </geometry>
                </collision>
                <visual name="pole_visual">
                    <geometry>
                        <cylinder>
                            <radius>0.05</radius>
                            <length>0.9</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient>0.3 0.3 0.3 1</ambient>
                        <diffuse>0.3 0.3 0.3 1</diffuse>
                        <specular>0.1 0.1 0.1 1</specular>
                    </material>
                </visual>
            </link>

            <!-- Camera body sitting on top of the pole (z = 1.0 m) -->
            <link name="camera_link">
                <pose>0 0 1.01 0 0 0</pose>
                <collision name="camera_collision">
                    <geometry>
                        <box>
                            <size>0.1 0.1 0.1</size>
                        </box>
                    </geometry>
                </collision>
                <visual name="camera_visual">
                    <geometry>
                        <box>
                            <size>0.1 0.1 0.1</size>
                        </box>
                    </geometry>
                    <material>
                        <ambient>0.1 0.1 0.8 1</ambient>
                        <diffuse>0.1 0.1 0.8 1</diffuse>
                        <specular>0.1 0.1 0.1 1</specular>
                    </material>
                </visual>

                <sensor name="camera_sensor" type="camera">
                    <pose>0 0 0 0 0 0</pose>
                    <camera>
                        <horizontal_fov>1.047</horizontal_fov>
                        <image>
                            <width>640</width>
                            <height>480</height>
                            <format>R8G8B8</format>
                        </image>
                        <clip>
                            <near>0.1</near>
                            <far>100</far>
                        </clip>
                    </camera>
                    <always_on>1</always_on>
                    <update_rate>30</update_rate>
                    <visualize>true</visualize>
                    <topic>/camera/image_raw</topic>
                </sensor>
            </link>

            <joint name="pole_to_camera" type="fixed">
                <parent>pole</parent>
                <child>camera_link</child>
            </joint>

        </model>


        <!-- Board mount: vertical pole at x=3 + horizontal arm to board centre -->
        <model name="board_stand">
            <static>false</static>
            <pose>0 0 0 0 0 3.1416</pose>

            <!-- Vertical pole: x=3, y=0, from z=0 to z=1 (centre at z=0.5) -->
            <link name="vertical_pole">
                <pose>3.0 0 0.5 0 0 0</pose>
                <collision name="vpole_collision">
                    <geometry>
                        <cylinder>
                            <radius>0.03</radius>
                            <length>1.0</length>
                        </cylinder>
                    </geometry>
                </collision>
                <visual name="vpole_visual">
                    <geometry>
                        <cylinder>
                            <radius>0.03</radius>
                            <length>1.0</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient>0.4 0.4 0.4 1</ambient>
                        <diffuse>0.4 0.4 0.4 1</diffuse>
                        <specular>0.2 0.2 0.2 1</specular>
                    </material>
                </visual>
            </link>

            <!-- Horizontal pole: from x=2 to x=3 at z=1 (centre at x=2.5, length=1.0)
                 Cylinder is Z-aligned by default, so rotate π/2 around Y to align with X -->
            <link name="horizontal_pole">
                <pose>2.5 0 1.0 0 1.5708 0</pose>
                <collision name="hpole_collision">
                    <geometry>
                        <cylinder>
                            <radius>0.03</radius>
                            <length>1.0</length>
                        </cylinder>
                    </geometry>
                </collision>
                <visual name="hpole_visual">
                    <geometry>
                        <cylinder>
                            <radius>0.03</radius>
                            <length>1.0</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient>0.4 0.4 0.4 1</ambient>
                        <diffuse>0.4 0.4 0.4 1</diffuse>
                        <specular>0.2 0.2 0.2 1</specular>
                    </material>
                </visual>
            </link>

            <link name="callibration_board_link">
                <pose>1.9 0 1 0 -1.5708 0</pose>
                <inertial>
                    <mass>0.5</mass>
                    <inertia>
                        <ixx>0.09375</ixx><iyy>0.09375</iyy><izz>0.1875</izz>
                    </inertia>
                </inertial>
               <collision name="board_collision">
                    <geometry>
                        <box>
                            <size>1.5 1.5 0.01</size>
                        </box>
                    </geometry>
                </collision>
                <visual name="board_visual">
                    <geometry>
                        <box>
                            <size>1.5 1.5 0.01</size>
                        </box>
                    </geometry>
                    <material>
                        <ambient>0.1 0.1 0.8 1</ambient>
                        <diffuse>0.1 0.1 0.8 1</diffuse>
                        <specular>0.1 0.1 0.3 1</specular>
                    </material>
                </visual>
            <visual name="top_surface">
                <!-- visual surface in front of the board -->
                <pose>0 0 0.01 0 0 -1.5708</pose>
                <geometry>
                    <plane>
                    <normal>0 0 1</normal>
                    <size>1.5 1.132</size>
                    </plane>
                </geometry>
                <material>
                    <ambient>1.0 1.0 1.0 1</ambient>
                    <diffuse>1.0 1.0 1.0 1</diffuse>
                    <specular>0.5 0.5 0.5 1</specular>
                    <pbr>
                        <metal>
                            <albedo_map>/home/johan/Documents/masters/ros2_fortress_ws/markers/charuco.png</albedo_map>
                        </metal>
                    </pbr>
                </material>
                </visual>

            </link>

            <joint name="world_to_vertical_pole" type="fixed">
                <parent>world</parent>
                <child>vertical_pole</child>
            </joint>

            <joint name="vertical_to_horizontal" type="fixed">
                <parent>vertical_pole</parent>
                <child>horizontal_pole</child>
            </joint>

            <!-- Intermediate link for pan (yaw) -->
            <link name="pan_link">
                <pose>1.9 0 1 0 0 0</pose>
                <inertial>
                    <mass>0.001</mass>
                    <inertia><ixx>0.000001</ixx><iyy>0.000001</iyy><izz>0.000001</izz></inertia>
                </inertial>
            </link>

            <!-- Intermediate link for tilt (pitch) -->
            <link name="tilt_link">
                <pose>1.9 0 1 0 0 0</pose>
                <inertial>
                    <mass>0.001</mass>
                    <inertia><ixx>0.000001</ixx><iyy>0.000001</iyy><izz>0.000001</izz></inertia>
                </inertial>
            </link>

            <!-- pan_joint: rotates the board around Z (yaw) -->
            <joint name="pan_joint" type="revolute">
                <parent>horizontal_pole</parent>
                <child>pan_link</child>
                <axis>
                    <xyz>0 0 1</xyz>
                    <limit>
                        <lower>-3.1416</lower>
                        <upper>3.1416</upper>
                    </limit>
                </axis>
            </joint>

            <!-- tilt_joint: rotates the board around Y (pitch) -->
            <joint name="tilt_joint" type="revolute">
                <parent>pan_link</parent>
                <child>tilt_link</child>
                <axis>
                    <xyz>0 1 0</xyz>
                    <limit>
                        <lower>-1.5708</lower>
                        <upper>1.5708</upper>
                    </limit>
                </axis>
            </joint>

            <!-- y_axis_joint: slides the board along Y -->
            <joint name="y_axis_joint" type="prismatic">
                <parent>tilt_link</parent>
                <child>callibration_board_link</child>
                <axis>
                    <xyz>0 1 0</xyz>
                    <limit>
                        <lower>-0.3</lower>
                        <upper>0.3</upper>
                    </limit>
                </axis>
            </joint>

            <!-- JointPositionController for pan_joint -->
            <plugin
                filename="libignition-gazebo-joint-position-controller-system.so"
                name="ignition::gazebo::systems::JointPositionController">
                <joint_name>pan_joint</joint_name>
                <topic>/pan_joint/position</topic>
                <p_gain>25.0</p_gain>
                <i_gain>1.0</i_gain>
                <d_gain>100.0</d_gain>
            </plugin>

            <!-- JointPositionController for tilt_joint -->
            <plugin
                filename="libignition-gazebo-joint-position-controller-system.so"
                name="ignition::gazebo::systems::JointPositionController">
                <joint_name>tilt_joint</joint_name>
                <topic>/tilt_joint/position</topic>
                <p_gain>25.0</p_gain>
                <i_gain>1.0</i_gain>
                <d_gain>100.0</d_gain>
            </plugin>

            <!-- JointPositionController for y_axis_joint -->
            <plugin
                filename="libignition-gazebo-joint-position-controller-system.so"
                name="ignition::gazebo::systems::JointPositionController">
                <joint_name>y_axis_joint</joint_name>
                <topic>/y_axis_joint/position</topic>
                <p_gain>25.0</p_gain>
                <i_gain>1.0</i_gain>
                <d_gain>100.0</d_gain>
            </plugin>

            <!-- Joint state publisher -->
            <plugin
                filename="libignition-gazebo-joint-state-publisher-system.so"
                name="ignition::gazebo::systems::JointStatePublisher">
                <joint_name>pan_joint</joint_name>
                <joint_name>tilt_joint</joint_name>
                <joint_name>y_axis_joint</joint_name>
            </plugin>

        </model>




    </world>
</sdf>