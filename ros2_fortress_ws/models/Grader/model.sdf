            <!-- Booth -->
            <visual name="booth_visual">
                <pose>0 0 0 0 0 0</pose>
                <geometry>
                <mesh>
                    <uri>model://Grader/Geometry/Booth.stl</uri>
                    <scale>1 1 1</scale>
