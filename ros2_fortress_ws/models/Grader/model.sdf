<?xml version="1.0" ?>
<sdf version="1.6">
<model name="grader">
            <static>false</static>
            
            <!-- Main Body Link -->
            <link name="base_link">
            <pose>0 0 1.485 0 0 0</pose>
            <inertial>
                <mass>15000.0</mass>
                <inertia>
                <ixx>5000.0</ixx>
                <iyy>12000.0</iyy>
                <izz>10000.0</izz>
                <ixy>0</ixy>
                <ixz>0</ixz>
                <iyz>0</iyz>
                </inertia>
            </inertial>
            
            <!-- Main Frame -->
            <visual name="main_frame_visual">
                <pose>0 0 0 0 0 0</pose>
                <geometry>
                <mesh>
                    <uri>model://Grader/Geometry/MainFrame.stl</uri>
                    <scale>1 1 1</scale>
                </mesh>
                </geometry>
                <material>
                <ambient>0.438 0.260 0 1</ambient>
                <diffuse>0.438 0.260 0 1</diffuse>
                <specular>1.0 1.0 1.0 1</specular>
                </material>
            </visual>
            
            <collision name="main_frame_collision">
                <pose>0 0 0 0 0 0</pose>
                <geometry>
                <mesh>
                    <uri>model://Grader/Geometry/MainFrame.stl</uri>
                    <scale>1 1 1</scale>
                </mesh>
                </geometry>
            </collision>
            
            <!-- Engine -->
