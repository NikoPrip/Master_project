            <!-- Grader Blade Link -->
            <link name="grader_blade">
            <pose> 2.35 0 0.293 0 0 0</pose> <!-- Changed from 2.562 0 0.243 0 0 0 -->
            <inertial>
                <mass>300.0</mass>
                <inertia>
                <ixx>25.0</ixx>
